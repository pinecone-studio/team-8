{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:artifacts": "node scripts/clean-build-artifacts.mjs",
    "dev": "next dev",
    "build": "npm run codegen && next build",
    "start": "next start",
    "lint": "eslint .",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "preview": "npm run clean:artifacts && npm run codegen && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run clean:artifacts && npm run codegen && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@apollo/client": "^3.12.9",
    "@clerk/nextjs": "^7.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "graphql": "^16.10.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "^16.1.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.6",
    "@graphql-codegen/typescript": "^4.1.5",
    "@graphql-codegen/typescript-operations": "^4.4.1",
    "@graphql-codegen/typescript-react-apollo": "^4.3.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "wrangler": "^4.72.0"
  }
}
